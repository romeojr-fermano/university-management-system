# Force LF line endings for all text files
* text=auto

# Explicit line endings for common file types
*.java text eol=lf
*.css text eol=lf
*.md text eol=lf
*.gradle text eol=lf
*.xml text eol=lf
*.fxml text eol=lf
*.sql text eol=lf
*.sh text eol=lf
*.properties text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
