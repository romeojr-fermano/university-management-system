<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import org.kordamp.ikonli.javafx.*?>

<StackPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="500.0"
           prefWidth="350.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.javafx.univesitymanagementsystem.controller.AuthController">
    <AnchorPane fx:id="login_form" prefHeight="500.0" prefWidth="350.0" styleClass="bg-form"
                stylesheets="@design/LoginForm.css">
        <Label layoutX="49.0" layoutY="91.0" styleClass="header" stylesheets="@design/LoginForm.css"
               text="Welcome Back!" textFill="#c0ffe4">
            <font>
                <Font name="Arial" size="18.0"/>
            </font>
        </Label>
        <TextField fx:id="login_username" layoutX="50.0" layoutY="182.0" prefHeight="30.0" prefWidth="250.0"
                   promptText="Username" styleClass="text-field" stylesheets="@design/LoginForm.css"/>
        <PasswordField fx:id="login_password" layoutX="50.0" layoutY="225.0" prefHeight="30.0" prefWidth="250.0"
                       promptText="Password" styleClass="text-field" stylesheets="@design/LoginForm.css"/>
        <FontIcon fill="#12ea8d" iconLiteral="fa-user" iconSize="24" layoutX="56.0" layoutY="205.0" text=""/>
        <FontIcon fill="#12ea8d" iconLiteral="fa-lock" iconSize="24" layoutX="57.0" layoutY="250.0"/>
        <Button fx:id="login_button" layoutX="49.0" layoutY="283.0" mnemonicParsing="false" prefHeight="40.0"
                prefWidth="134.0" styleClass="btn" stylesheets="@design/LoginForm.css" text="LOGIN"/>
        <HBox alignment="CENTER" layoutY="463.0" prefWidth="350.0" spacing="5.0">
            <Label layoutX="44.0" layoutY="465.0" text="Don't have an account?" textFill="WHITE"/>
            <ComboBox fx:id="login_role" layoutX="173.0" layoutY="461.0" onAction="#switchSignupForm" prefWidth="150.0"
                      promptText="Choose Role"/>
        </HBox>
    </AnchorPane>
    <AnchorPane fx:id="admin_register_form" prefHeight="500.0" prefWidth="350.0" styleClass="bg-form"
                stylesheets="@design/LoginForm.css" visible="false">
        <Label layoutX="49.0" layoutY="91.0" styleClass="header" stylesheets="@design/LoginForm.css"
               text="Register Account" textFill="#c0ffe4">
            <font>
                <Font name="Arial" size="18.0"/>
            </font>
        </Label>
        <TextField fx:id="admin_username" layoutX="50.0" layoutY="182.0" prefHeight="30.0" prefWidth="250.0"
                   promptText="Username" styleClass="text-field" stylesheets="@design/LoginForm.css"/>
        <PasswordField fx:id="admin_password" layoutX="50.0" layoutY="225.0" prefHeight="30.0" prefWidth="250.0"
                       promptText="Password" styleClass="text-field" stylesheets="@design/LoginForm.css"/>
        <FontIcon fill="#12ea8d" iconLiteral="fa-user" iconSize="24" layoutX="56.0" layoutY="205.0"/>
        <FontIcon fill="#12ea8d" iconLiteral="fa-lock" iconSize="24" layoutX="57.0" layoutY="250.0"/>
        <Button fx:id="admin_signup_button" layoutX="49.0" layoutY="350.0" mnemonicParsing="false" prefHeight="40.0"
                prefWidth="134.0" styleClass="btn" stylesheets="@design/LoginForm.css" text="SIGNUP"
                onAction="#handleSignup"/>

        <Label layoutX="52.0" layoutY="121.0" text="Admin" textFill="#c0ffe4">
            <font>
                <Font size="14.0"/>
            </font>
        </Label>
        <PasswordField fx:id="admin_confirm_password" layoutX="50.0" layoutY="265.0" prefHeight="30.0" prefWidth="250.0"
                       promptText="Confirm Password" styleClass="text-field" stylesheets="@design/LoginForm.css"/>
        <FontIcon fill="#12ea8d" iconLiteral="fa-lock" iconSize="24" layoutX="57.0" layoutY="290.0" text=""/>
        <HBox alignment="CENTER" layoutY="463.0" prefWidth="350.0" spacing="5.0">
            <Label text="Already have an account?" textFill="WHITE"/>
            <Hyperlink fx:id="admin_sign_in" onAction="#signIn" text="Sign in here" textFill="#4debef"/>
        </HBox>
    </AnchorPane>
    <AnchorPane fx:id="student_signup_form" prefHeight="500.0" prefWidth="350.0" styleClass="bg-form"
