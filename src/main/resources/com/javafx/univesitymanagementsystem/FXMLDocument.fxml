                       prefWidth="250.0" promptText="Confirm Password" styleClass="text-field"
                       stylesheets="@design/LoginForm.css"/>
        <FontIcon fill="#12ea8d" iconLiteral="fa-envelope" iconSize="20" layoutX="55.0" layoutY="153.0" text=""/>
        <FontIcon fill="#12ea8d" iconLiteral="fa-user" iconSize="24" layoutX="56.0" layoutY="198.0"/>
        <FontIcon fill="#12ea8d" iconLiteral="fa-lock" iconSize="24" layoutX="57.0" layoutY="243.0"/>
        <FontIcon fill="#12ea8d" iconLiteral="fa-lock" iconSize="24" layoutX="57.0" layoutY="288.0"/>
        <Button fx:id="student_signup_button" layoutX="49.0" layoutY="330.0" mnemonicParsing="false" prefHeight="40.0"
                prefWidth="134.0" styleClass="btn" stylesheets="@design/LoginForm.css" text="SIGNUP"
                onAction="#handleSignup"/>
        <HBox alignment="CENTER" layoutY="463.0" prefWidth="350.0" spacing="5.0">
            <Label text="Already have an account?" textFill="WHITE"/>
            <Hyperlink fx:id="student_sign_in" onAction="#signIn" text="Sign in here" textFill="#4debef"/>
        </HBox>
    </AnchorPane>
